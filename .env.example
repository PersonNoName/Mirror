# ============ LLM Provider ============
# 可选值: minimax | openai | ollama (默认为 openai)
# 当 LLM_PROVIDER=minimax 时使用 MiniMax Coding Plan
OPENAI_API_KEY=sk-...  # 通用 API Key
LLM_PROVIDER=minimax
LLM_BASE_URL=https://api.minimax.chat/v1  # MiniMax API 地址
LLM_MODEL=MiniMax-Text-01
# 当 LLM_PROVIDER=ollama 时:
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_LLM_MODEL=llama3

# ============ Embedding Provider ============
# 可选值: ollama | openai | minimax (留空则使用 Dummy)
EMBEDDING_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
EMBEDDING_MODEL=text-embedding-3-small

# ============ Redis ============
REDIS_URL=redis://localhost:6379

# ============ PostgreSQL ============
POSTGRES_URL=postgresql://user:pass@localhost:5432/mirror

# ============ Qdrant (向量数据库，可选) ============
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ============ Neo4j (图数据库，可选) ============
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ============ Agent Application ============
AGENT_HOST=0.0.0.0
AGENT_PORT=8000
LOG_LEVEL=INFO
