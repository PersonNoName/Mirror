# ============ LLM (OpenAI 兼容接口，如 MiniMax) ============
OPENAI_API_KEY=sk-...
LLM_BASE_URL=https://api.minimax.chat/v1  # OpenAI 兼容地址
LLM_MODEL=MiniMax-Text-01

# ============ Redis ============
REDIS_URL=redis://localhost:6379

# ============ PostgreSQL ============
POSTGRES_URL=postgresql://user:pass@localhost:5432/mirror

# ============ Qdrant (向量数据库，可选) ============
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ============ Neo4j (图数据库，可选) ============
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ============ Agent Application ============
AGENT_HOST=0.0.0.0
AGENT_PORT=8000
LOG_LEVEL=INFO
