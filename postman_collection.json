{
  "info": {
    "name": "Mirror API",
    "description": "Mirror 本地优先 AI Agent 运行时 API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:8000"
    }
  ],
  "item": [
    {
      "name": "健康检查",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        },
        "description": "检查服务健康状态"
      },
      "response": []
    },
    {
      "name": "同步对话",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"你好\",\n  \"session_id\": \"test-session-1\",\n  \"user_id\": \"user-1\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/chat",
          "host": ["{{baseUrl}}"],
          "path": ["chat"]
        },
        "description": "同步对话接口"
      },
      "response": []
    },
    {
      "name": "流式对话",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/chat/stream?session_id=test-session-1",
          "host": ["{{baseUrl}}"],
          "path": ["chat", "stream"],
          "query": [
            {
              "key": "session_id",
              "value": "test-session-1",
              "description": "会话ID"
            }
          ]
        },
        "description": "SSE 流式对话接口"
      },
      "response": []
    },
    {
      "name": "查看记忆列表",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/memory?user_id=user-1&include_candidates=true&include_superseded=false&include_mid_term=true",
          "host": ["{{baseUrl}}"],
          "path": ["memory"],
          "query": [
            {
              "key": "user_id",
              "value": "user-1",
              "description": "用户ID"
            },
            {
              "key": "include_candidates",
              "value": "true",
              "description": "是否包含候选记忆"
            },
            {
              "key": "include_superseded",
              "value": "false",
              "description": "是否包含已被替代/删除的记忆"
            },
            {
              "key": "include_mid_term",
              "value": "true",
              "description": "是否包含跨 session 的中期记忆"
            }
          ]
        },
        "description": "查看用户可治理记忆列表"
      },
      "response": []
    },
    {
      "name": "查看中期记忆",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/memory/mid-term?user_id=user-1&include_expired=false",
          "host": ["{{baseUrl}}"],
          "path": ["memory", "mid-term"],
          "query": [
            {
              "key": "user_id",
              "value": "user-1",
              "description": "用户ID"
            },
            {
              "key": "include_expired",
              "value": "false",
              "description": "是否包含已过期的中期记忆"
            }
          ]
        },
        "description": "查看用户跨 session 的中期记忆列表"
      },
      "response": []
    },
    {
      "name": "查看对话片段回忆",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/memory/conversation-episodes?user_id=user-1&limit=20",
          "host": ["{{baseUrl}}"],
          "path": ["memory", "conversation-episodes"],
          "query": [
            {
              "key": "user_id",
              "value": "user-1",
              "description": "用户ID"
            },
            {
              "key": "limit",
              "value": "20",
              "description": "返回条数，范围 1-100"
            }
          ]
        },
        "description": "查看 conversation_episode 中保存的历史对话摘要片段"
      },
      "response": []
    },
    {
      "name": "查看记忆治理策略",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/memory/governance?user_id=user-1",
          "host": ["{{baseUrl}}"],
          "path": ["memory", "governance"],
          "query": [
            {
              "key": "user_id",
              "value": "user-1",
              "description": "用户ID"
            }
          ]
        },
        "description": "查看用户当前记忆治理策略"
      },
      "response": []
    },
    {
      "name": "阻止记忆学习",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_id\": \"user-1\",\n  \"content_class\": \"support_preference\",\n  \"blocked\": true\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/memory/governance/block",
          "host": ["{{baseUrl}}"],
          "path": ["memory", "governance", "block"]
        },
        "description": "阻止某类内容继续学习"
      },
      "response": []
    },
    {
      "name": "修正记忆",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_id\": \"user-1\",\n  \"memory_key\": \"inference:tone:direct\",\n  \"corrected_content\": \"用户更喜欢详细谨慎的回答\",\n  \"truth_type\": \"fact\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/memory/correct",
          "host": ["{{baseUrl}}"],
          "path": ["memory", "correct"]
        },
        "description": "修正指定记忆内容"
      },
      "response": []
    },
    {
      "name": "删除长期记忆",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_id\": \"user-1\",\n  \"memory_key\": \"fact:tone:direct\",\n  \"reason\": \"信息有误\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/memory/delete",
          "host": ["{{baseUrl}}"],
          "path": ["memory", "delete"]
        },
        "description": "删除指定长期记忆"
      },
      "response": []
    },
    {
      "name": "删除中期记忆",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_id\": \"user-1\",\n  \"memory_key\": \"mid_term:project:mirror_memory_rollout\",\n  \"reason\": \"不再需要保留这个近期上下文\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/memory/mid-term/delete",
          "host": ["{{baseUrl}}"],
          "path": ["memory", "mid-term", "delete"]
        },
        "description": "删除或压制中期记忆，避免再次召回或晋升"
      },
      "response": []
    },
    {
      "name": "查看进化日志",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/evolution/journal?user_id=user-1&limit=10",
          "host": ["{{baseUrl}}"],
          "path": ["evolution", "journal"],
          "query": [
            {
              "key": "user_id",
              "value": "user-1",
              "description": "用户ID"
            },
            {
              "key": "limit",
              "value": "10",
              "description": "返回条数上限"
            }
          ]
        },
        "description": "查看系统进化日志"
      },
      "response": []
    },
    {
      "name": "HITL 任务响应",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"task_id\": \"task-1\",\n  \"decision\": \"approve\",\n  \"payload\": {\n    \"safe\": true\n  }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/hitl/respond",
          "host": ["{{baseUrl}}"],
          "path": ["hitl", "respond"]
        },
        "description": "人工审批 HITL 任务，decision 可选 approve/reject/defer"
      },
      "response": []
    }
  ]
}
